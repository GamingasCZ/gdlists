{
  "name": "gdlists-vue",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "network": "vite --host",
    "build": "run-p type-check build-only",
    "preview": "vite preview",
    "build-only": "node serverConfig/getCommit.js && vite build && node serverConfig/deployPHP.js",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "axios": "^1.16.1",
    "chroma-js": "2.4.2",
    "cookier": "^3.1.0",
    "marked": "^18.0.4",
    "pure-editor": "file:modules/pure-editor",
    "striptags": "^3.2.0",
    "vue": "*",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.16.1",
    "@types/chroma-js": "2.4.0",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^7.1.0",
    "@vue/eslint-config-typescript": "^11.0.3",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "git-last-commit": "^1.0.1",
    "node-html-parser": "^7.1.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.15",
    "prettier": "^2.8.8",
    "prettier-plugin-tailwindcss": "^0.2.8",
    "rollup-plugin-copy": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vue-tsc": "^3.3.2"
  }
}
