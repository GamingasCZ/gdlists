{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "compilerOptions": {
    "lib": ["ES2025", "DOM"],
    "target": "es2025",
    "paths": {
      "@/*": ["./src/*"]
    },
    "noImplicitAny": false,
    "allowJs": false
  },

  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
